{
  "name": "margin",
  "version": "0.1.0",
  "description": "A minimal Markdown writing app for saving directly into an Obsidian vault.",
  "author": "LinJinl",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "package:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "app.margin.writer",
    "productName": "Margin",
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "README.md"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
