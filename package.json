{
  "name": "margin",
  "version": "0.1.0",
  "description": "A minimal Markdown writing app for saving directly into an Obsidian vault.",
  "author": "LinJinl",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "node scripts/dev-watch.js",
    "dev:debug": "MARGIN_DEVTOOLS=1 node scripts/dev-watch.js",
    "package:mac": "electron-builder --mac",
    "package:mac:dir": "electron-builder --mac --dir",
    "install:mac": "npm run package:mac:dir && node scripts/install-macos.js",
    "open:mac": "open \"$HOME/Applications/Margin.app\""
  },
  "build": {
    "appId": "app.margin.writer",
    "productName": "Margin",
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "README.md"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
